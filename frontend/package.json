{
  "name": "bytebank",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build --turbopack",
    "build:analyze": "cross-env ANALYZE=true next build",
    "build:staging": "cross-env NEXT_PUBLIC_DEPLOY_ENV=staging next build --turbopack",
    "perf:budget": "node scripts/validate-performance-budget.mjs",
    "staging:validate": "npm run build:staging && npm run perf:budget",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:storybook": "vitest --config vitest.storybook.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@carollyb/bank-design-system": "^1.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.4",
    "@mui/material": "^7.3.4",
    "@mui/x-date-pickers": "^8.19.0",
    "cookie": "^1.1.1",
    "dayjs": "^1.11.19",
    "next": "15.5.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-infinite-scroll-component": "^6.1.0",
    "swr": "^2.3.6",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.1",
    "@next/bundle-analyzer": "^15.5.9",
    "cross-env": "^7.0.3",
    "@eslint/eslintrc": "^3",
    "@storybook/addon-a11y": "^9.1.13",
    "@storybook/addon-docs": "^9.1.13",
    "@storybook/addon-vitest": "^9.1.13",
    "@storybook/nextjs-vite": "^9.1.13",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "eslint-plugin-storybook": "^9.1.13",
    "jsdom": "^29.1.1",
    "playwright": "^1.56.1",
    "storybook": "^9.1.13",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
